{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "日志速率 (每秒)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\"} [5m])) by (container_name)",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "错误日志数量",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({job=\"docker\", container_name=~\"scratch-backend.*\"} |~ \"(?i)error\" [1h])",
          "legendFormat": "错误数"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "告警日志数量",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({job=\"docker\", container_name=~\"scratch-backend.*\"} |~ \"(?i)warn\" [1h])",
          "legendFormat": "告警数"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "后端应用日志",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"docker\", container_name=~\"scratch-backend.*\"} | level=~\"${level:regex}\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "HTTP 请求日志",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"docker\", container_name=~\"scratch-backend.*\"} |~ \"(GET|POST|PUT|DELETE|PATCH)\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Nginx 访问日志",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"docker\", container_name=~\"scratch-frontend.*\"} | status=~\"${status:regex}\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["scratch", "logs"],
  "templating": {
    "list": [
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "Loki" }
      },
      {
        "name": "level",
        "type": "custom",
        "label": "日志级别",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "ERROR", "value": "ERROR" },
          { "text": "WARN", "value": "WARN" },
          { "text": "INFO", "value": "INFO" },
          { "text": "DEBUG", "value": "DEBUG" }
        ]
      },
      {
        "name": "status",
        "type": "custom",
        "label": "HTTP 状态码",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "2xx", "value": "2.*", "selected": false },
          { "text": "3xx", "value": "3.*", "selected": false },
          { "text": "4xx", "value": "4.*", "selected": false },
          { "text": "5xx", "value": "5.*", "selected": false }
        ]
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Scratch 社区 - 日志面板",
  "uid": "scratch-logs",
  "version": 1
}
