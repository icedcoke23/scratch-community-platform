# ============================================================
# Scratch Community Platform - 环境变量配置模板
# 复制此文件为 .env 并修改所有敏感配置
#
# 使用方式:
#   开发环境: cp .env.example .env && 修改配置
#   Docker:   docker-compose --env-file .env up -d
#
# ⚠️ 安全警告: 绝对不要将 .env 文件提交到 Git！
# ============================================================

# ---------- MySQL ----------
# ⚠️ 必须修改！不要使用弱密码
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_strong_password_here
MYSQL_DATABASE=scratch_community
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- MinIO ----------
# ⚠️ 必须修改！不要使用默认凭据
MINIO_ROOT_USER=CHANGE_ME_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_strong_password_here
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_admin
MINIO_SECRET_KEY=CHANGE_ME_minio_strong_password_here
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- JWT ----------
# ⚠️ 生产环境必须修改！至少 32 字节
# 生成方法: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_bytes_random

# ---------- 后端 ----------
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/scratch_community?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
SPRING_DATA_REDIS_HOST=localhost
BACKEND_PORT=8080
JAVA_OPTS=-Xms256m -Xmx512m

# ---------- 沙箱 ----------
SANDBOX_URL=http://localhost:8081
SANDBOX_PORT=8081

# ---------- AI 点评（可选） ----------
# 设置为 true 启用 LLM 点评，未配置时自动降级为规则引擎
AI_ENABLED=false
# 提供商: openai / qwen / deepseek / ollama
AI_PROVIDER=openai
# API Key（从对应平台获取）
AI_API_KEY=
# API 地址（不同提供商不同）
# OpenAI: https://api.openai.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com/v1
# Ollama: http://localhost:11434/v1
AI_BASE_URL=https://api.openai.com/v1
# 模型名称
AI_MODEL=gpt-4o-mini
# 超时和 token 限制
AI_TIMEOUT=30000
AI_MAX_TOKENS=2000

# ---------- 前端 ----------
FRONTEND_PORT=3000

# ---------- 生产环境检查清单 ----------
# [ ] JWT_SECRET 已替换为随机密钥 (openssl rand -base64 32)
# [ ] MYSQL_ROOT_PASSWORD 已替换为强密码
# [ ] MINIO_ROOT_USER/PASSWORD 已替换
# [ ] SPRING_PROFILES_ACTIVE 设为 prod
# [ ] MySQL/Redis/MinIO 端口未暴露到外网
# [ ] 已配置 HTTPS (Nginx + Let's Encrypt)
# [ ] 已配置日志持久化目录
